# ── Home Connect (developer.home-connect.com → Applications) ─────────────
HC_CLIENT_ID=your-home-connect-client-id
HC_CLIENT_SECRET=your-home-connect-client-secret
# Scopes (Space-getrennt):
HC_SCOPES=IdentifyAppliance Monitor Control Settings Dishwasher Washer Dryer CoffeeMaker Oven

# ── Nur für LOKALE ENTWICKLUNG (Remote Plugin außerhalb der HCU) ──────────
# Wenn das Plugin im HCU-Container läuft, werden diese Werte NICHT gebraucht.
# HCU_HOST=hcu1-xxxx.local
# HCU_AUTH_TOKEN=paste-auth-token-here

# ── Sonstiges ─────────────────────────────────────────────────────────────
HCU_PLUGIN_ID=de.eq3.homeconnect
LOG_LEVEL=info
# Im Container auf der HCU: Token-Storage ist /data/tokens.json (automatisch)
# Für lokale Entwicklung kann das überschrieben werden:
# TOKEN_STORE=./data/tokens.json
