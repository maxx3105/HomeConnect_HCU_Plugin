# --- Home Connect (developer.home-connect.com -> Applications) ---
HC_CLIENT_ID=your-home-connect-client-id
HC_CLIENT_SECRET=your-home-connect-client-secret
# Space-separated scopes. Mind. IdentifyAppliance + Monitor + Control + pro Gerätetyp.
HC_SCOPES=IdentifyAppliance Monitor Control Settings Dishwasher Washer Dryer CoffeeMaker Oven

# --- HCU (HCUweb -> Entwicklermodus) ---
# Host ODER IP der HCU, ohne Protokoll:
HCU_HOST=hcu1-xxxx.local
# Plugin-Auth-Token aus dem Entwicklermodus (HCUweb erzeugt diesen):
HCU_AUTH_TOKEN=paste-plugin-auth-token-here
# Plugin-ID muss zur plugin-description.json passen:
HCU_PLUGIN_ID=de.eq3.homeconnect
# TLS-Verification deaktivieren (self-signed Cert der HCU)? 1 = ja, 0 = nein.
HCU_INSECURE_TLS=1

# --- Sonstiges ---
LOG_LEVEL=info
TOKEN_STORE=./data/tokens.json
